table 'Data Exports'
	lineageTag: ec1a8c6a-9269-4900-b17f-4560b726a10d

	measure 'Export Duration Avg (Sec)' = DIVIDE(AVERAGE('Data Exports'[DurationMs]), 1000)
		formatString: #,0.00
		lineageTag: 9b1d8522-ab9f-4aac-b973-dbf6b89fcf7e

	measure 'Export Query Processing CPU Time Avg (Sec)' = DIVIDE(AVERAGE('Data Exports'[QueryProcessingCpuTimeMs]), 1000)
		formatString: #,0.00
		lineageTag: b9670a43-372d-4015-87f7-ea95645bf8fd

	measure 'Export Query Processing CPU Time Sum (Sec)' = DIVIDE(SUM('Data Exports'[QueryProcessingCpuTimeMs]), 1000)
		formatString: 0.00
		lineageTag: c721616a-46c3-4094-ae6f-4a156a1992ac

	measure 'Export Total CPU Time Sum (Sec)' = DIVIDE(SUM('Data Exports'[TotalCpuTimeMs]), 1000)
		formatString: #,0.00
		lineageTag: 7ac0be6b-c3a1-4b90-80b2-656cddb89ff8

	measure 'Export Total CPU Time Avg (Sec)' = DIVIDE(AVERAGE('Data Exports'[TotalCpuTimeMs]), 1000)
		formatString: #,0.00
		lineageTag: 0966aca3-b248-49e0-81a3-c258f4148cee

	measure 'Total Rows Exported' = SUM('Data Exports'[QueryResultRows])
		formatString: #,0
		lineageTag: ba3da4d1-4388-45bf-8824-d385c362269c

	measure 'Export Peak Memory Consumption KB Avg' = AVERAGE('Data Exports'[ApproximatePeakMemConsumptionKB])
		lineageTag: 64e3089c-793b-4037-abeb-7a782bed4358

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Exports = CALCULATE(COUNTROWS('Data Exports'), KEEPFILTERS('Export Types'[Export Type] <> "Scroll Down"), KEEPFILTERS(NOT(ISBLANK(Visuals[Performance Key]))))
		formatString: #,0
		lineageTag: b14472f0-fbc5-4bb8-b81f-709dca0e42ff

	measure 'Scroll Down in Visuals' = CALCULATE(COUNTROWS('Data Exports'), KEEPFILTERS('Data Exports'[Export Type] = "Scroll Down"), KEEPFILTERS(NOT(ISBLANK(Visuals[Performance Key]))))
		formatString: #,0
		lineageTag: a478e78f-4a88-4333-bddf-5715ded36d8d

	measure 'Export Heatmap Performance' =
			
			VAR _x_cell_size = [X Heatmap Cell Size]
			VAR _y_cell_size = [Y Heatmap Cell Size]
			VAR _x = MAX('X Dimension'[X]) * _x_cell_size
			VAR _y = MAX('Y Dimension'[Y]) * _y_cell_size
			VAR _result =
			CALCULATE(
			    [Export Metric Value],
			    KEEPFILTERS (
			        Visuals[X] < _x && Visuals[X] + Visuals[Width] > _x + _x_cell_size &&
			        Visuals[Y] < _y && Visuals[Y] + Visuals[Height] > _y + _y_cell_size
			    )
			)
			RETURN
			_result
		formatString: #,0
		lineageTag: 14fbbf4f-6a9f-4ea7-ba75-e8efa7755927

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Export DAX Query' =
			
			VAR _x = ISFILTERED('X Dimension'[X])
			VAR _performance_key = [Performance Key in Heatmap]
			RETURN
			IF (
			    NOT(_x),
			    MAX('Data Exports'[DAXQuery]),
			    CALCULATE (
			        MAX('Data Exports'[DAXQuery]),
			        KEEPFILTERS(Visuals[Performance Key] = _performance_key)
			    )
			)
		lineageTag: 2dfad6b9-0c10-426e-b2ac-a8ddd627bc05

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Average # of Rows Exported' = AVERAGE('Data Exports'[QueryResultRows])
		formatString: #,0.0
		lineageTag: b37ca267-c729-42df-95d0-873635fb09ad

	measure 'Export Metric Value' = ```
			
			    SWITCH (
			        SELECTEDVALUE('Export Metrics'[Export Metric]),
			        "Total Rows Exported", [Total Rows Exported],
			        "# of Exports", [Exports],
			        "Duration Avg (Sec)", [Export Duration Avg (Sec)],
			        "Total CPU Time (Sec)", [Export Total CPU Time Sum (Sec)],
			        "Peak Memory Avg (KB)", [Export Peak Memory Consumption KB Avg],
			        BLANK()
			    )
			
			```
		lineageTag: 6ea7998b-0cc6-43f1-b723-512cdc02eb16

		formatStringDefinition =
				
				VAR _metric = SELECTEDVALUE('Export Metrics'[Export Metric])
				RETURN
				IF(_metric IN {"Duration Avg (Sec)", "Peak Memory Avg (KB)"}, "#,0.00", "#,0")

	measure 'Last Export Date' = MAX('Data Exports'[Date])
		lineageTag: 7c4f05be-8086-4378-a715-26a593efa596

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Export Heatmap Title' = ```
			
			VAR _page_name = 
			CALCULATE (
			    MAX('Pages'[Page Name]),
			    TOPN(1, 'Pages', [Export Metric Value], DESC)
			)
			RETURN
			IF(ISBLANK([Export Metric Value]) || ISBLANK([Scanned visuals]), "No data found",
			"Selected Page: '" & _page_name & "'")
			```
		lineageTag: 5ee9cf0c-34bf-4cce-8ab2-d30a8c02cab5

		annotation PBI_FormatHint = {"isText":true}

