	partition 'Data Exports' = m
		mode: import
		source = ```
				let
				
				    ADLSPathDelimiter = if #"Is SaaS" then "-" else "/",
				    Source = AzureStorage.DataLake(#"Data Lake URL" & ADLSPathDelimiter & #"License Key"),
				    
				    #"Filtered Rows1" = Table.SelectRows(Source, each Text.StartsWith([Folder Path], #"Data Lake URL" & ADLSPathDelimiter  & #"License Key" & "/log_analytics/queries")),
				    #"Filtered Hidden Files1" = Table.SelectRows(#"Filtered Rows1", each [Attributes]?[Hidden]? <> true),
				    #"Filter N Last Days" = Table.SelectRows(#"Filtered Hidden Files1", each if #"Last N Days Log Analytics" < 0 then true else [Date modified] > Date.AddDays(DateTime.FixedLocalNow(),-#"Last N Days Log Analytics")),
				    #"Removed Other Columns" = Table.SelectColumns(#"Filter N Last Days",{"Content", "Name", "Date modified"}),
				    #"Invoked Custom Function" = Table.AddColumn(#"Removed Other Columns", "FnGetLogAnalyticsExportEvents", each FnGetLogAnalyticsExportEvents([Content])),
				    #"Added Custom" = Table.AddColumn(#"Invoked Custom Function", "Export Logs", each Table.RowCount([FnGetLogAnalyticsExportEvents])),
				    #"Filtered Files with Exports" = Table.SelectRows(#"Added Custom", each [Export Logs] > 0),
				    #"RemovedExportLogs" = Table.RemoveColumns(#"Filtered Files with Exports",{"Export Logs"}),
				    #"Invoked Custom Function1" = Table.AddColumn(#"RemovedExportLogs", "FnGetLogAnalyticsVisualEvent", each FnGetLogAnalyticsVisualEvent([Content])),
				    #"Invoked Custom Function2" = Table.AddColumn(#"Invoked Custom Function1", "FnGetVisualInfoForExportEvents", each FnGetVisualInfoForExportEvents([FnGetLogAnalyticsExportEvents], [FnGetLogAnalyticsVisualEvent])),
				    #"Removed Columns" = Table.RemoveColumns(#"Invoked Custom Function2",{"FnGetLogAnalyticsExportEvents", "FnGetLogAnalyticsVisualEvent"}),
				    #"Renamed Columns" = Table.RenameColumns(#"Removed Columns",{{"Name", "Log Analytics File"}}),
				    #"Removed Columns1" = Table.RemoveColumns(#"Renamed Columns",{"Content", "Date modified"}),
				    
				    ExpandedColumns = Table.ExpandTableColumn(#"Removed Columns1", "FnGetVisualInfoForExportEvents",
				        {"TimeGenerated", "User", "QueryResultRows", "DurationMs", "QueryProcessingCpuTimeMs", "TotalCpuTimeMs", "ApproximatePeakMemConsumptionKB", "Max Rows", "Export Type", "PowerBIWorkspaceId", "ReportId", "VisualId", "Confidence", "NewDatasetId", "DAXQuery"},
				        {"TimeGenerated", "User", "QueryResultRows", "DurationMs", "QueryProcessingCpuTimeMs", "TotalCpuTimeMs", "ApproximatePeakMemConsumptionKB", "Max Rows", "Export Type", "PowerBIWorkspaceId", "ReportId", "VisualId", "Confidence", "NewDatasetId", "DAXQuery"}),
				    #"Filtered Rows" = Table.SelectRows(ExpandedColumns, each [VisualId] <> null and [VisualId] <> ""),
				    #"Renamed Columns1" = Table.RenameColumns(#"Filtered Rows",{{"NewDatasetId", "DatasetId"}}),
				    #"Changed Type" = Table.TransformColumnTypes(#"Renamed Columns1",{{"Log Analytics File", type text}, {"TimeGenerated", type datetimezone}, {"DAXQuery", type text}, {"User", type text}, {"QueryResultRows", Int64.Type}, {"DurationMs", Int64.Type}, {"QueryProcessingCpuTimeMs", Int64.Type}, {"TotalCpuTimeMs", Int64.Type}, {"ApproximatePeakMemConsumptionKB", Int64.Type}, {"Max Rows", Int64.Type}, {"Export Type", type text}, {"ReportId", type text}, {"VisualId", type text}, {"Confidence", type number}, {"DatasetId", type text}}),
				    #"Inserted Date" = Table.AddColumn(#"Changed Type", "Date", each DateTime.Date([TimeGenerated]), type date),
				    #"Inserted Time" = Table.AddColumn(#"Inserted Date", "Time", each DateTime.Time([TimeGenerated]), type time),
				    #"Removed Columns2" = Table.RemoveColumns(#"Inserted Time",{"Log Analytics File", "TimeGenerated"}),
				    #"Merged Queries" = Table.NestedJoin(#"Removed Columns2", {"ReportId", "DatasetId"}, #"PBI Reports - Base", {"Report ID", "Dataset ID"}, "PBI Reports - Base", JoinKind.LeftOuter),
				    #"Expanded PBI Reports - Base" = Table.ExpandTableColumn(#"Merged Queries", "PBI Reports - Base", {"Workspace ID", "Report Key"}, {"Report Workspace ID", "Report Key"}),
				    #"Add Performance Key" = Table.AddColumn(#"Expanded PBI Reports - Base", "Performance Key", each Text.Lower([ReportId] & "---" & [VisualId])),
				    #"Removed Columns3" = Table.RemoveColumns(#"Add Performance Key",{"Report Workspace ID", "Report Key", "DatasetId", "VisualId", "ReportId", "PowerBIWorkspaceId"}),
				    
				    NonDemoStep = #"Removed Columns3",
				    
				    FirstDemoStep = Table.AddIndexColumn(NonDemoStep, "Index", 1, 1, Int64.Type),
				    #"Calculated Modulo" = Table.TransformColumns(FirstDemoStep, {{"Index", each 1 + Number.Mod(_, 23), type number}}),
				    MergedDemoUsers = Table.NestedJoin(#"Calculated Modulo", {"Index"}, #"Users Demo", {"Index"}, "Users Demo", JoinKind.LeftOuter),
				    #"Expanded Users Demo" = Table.ExpandTableColumn(MergedDemoUsers, "Users Demo", {"User Key"}, {"User Key"}),
				    #"Removed Columns4" = Table.RemoveColumns(#"Expanded Users Demo",{"User"}),
				    #"Renamed Columns2" = Table.RenameColumns(#"Removed Columns4",{{"User Key", "User"}}),
				    LastDemoStep = Table.RemoveColumns(#"Renamed Columns2",{"Index"}),
				    LastStep = if #"Is Demo" then LastDemoStep else NonDemoStep
				in
				    LastStep
				```

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

