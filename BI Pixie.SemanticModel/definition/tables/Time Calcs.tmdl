		calculationItem 'PM MTD' =
				
				VAR _filter = DATEADD('Calendar'[Date], -1, MONTH )
				RETURN
				IF (
				    COUNTROWS( _filter ) = 0,
				    BLANK(),
				    CALCULATE (
				        SELECTEDMEASURE(),
				        'Time Calcs'[Calc] = "MTD",
				        _filter
