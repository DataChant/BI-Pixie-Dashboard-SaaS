table 'Time Calcs'
	lineageTag: c761c3ff-4548-4970-9e09-1184d42aae58

	calculationGroup

		calculationItem 'Current period' = ```
				
				SELECTEDMEASURE()
				
				```

		calculationItem Total = CALCULATE ( SELECTEDMEASURE(), ALL(Calendar) )

		calculationItem MTD =
				
				CALCULATE (
				    SELECTEDMEASURE(),
				    DATESMTD ( 'Calendar'[Date] )
				)

		calculationItem QTD =
				
				CALCULATE (
				    SELECTEDMEASURE(),
				    'Time Calcs'[Calc] = "Current",
				    DATESQTD ( 'Calendar'[Date] )
				)

		calculationItem YTD = ```
				
				    CALCULATE (
				        SELECTEDMEASURE(),
				        DATESYTD ( 'Calendar'[Date] )
				    )
				```

		calculationItem PM =
				
				VAR _filter = DATEADD ( 'Calendar'[Date], -1, MONTH )
				RETURN
				IF (
				    COUNTROWS( _filter ) = 0,
				    BLANK(),
				    CALCULATE (
				        SELECTEDMEASURE(),
				        'Time Calcs'[Calc] = "Current",
				        _filter
				    )
				)

		calculationItem MOM = ```
				
				VAR _prev = 
				CALCULATE(
				    SELECTEDMEASURE(),
				    'Time Calcs'[Calc] = "PM"
				)
				RETURN
				IF (
				    ISBLANK( _prev),
				    BLANK(),
				    SELECTEDMEASURE() -
				    _prev
				)
				
				```

		calculationItem MOM% = ```
				VAR _current = SELECTEDMEASURE()
				VAR _prev = 
				CALCULATE(
				    SELECTEDMEASURE(),
				    'Time Calcs'[Calc] = "PM"
				)
				RETURN
				IF (
				    ISBLANK( _prev) || _prev = 0 || ISBLANK(_current),
				    BLANK(),
				    DIVIDE(
				        _current,
				        _prev
				    ) - 1
				)
				```

			formatStringDefinition = IF(CALCULATE(SELECTEDMEASURE(), 'Time Calcs'[Calc] = "MOM") = 0, "0%", "#,#.0%")

		calculationItem PY =
				
				VAR _filter = SAMEPERIODLASTYEAR( 'Calendar'[Date] )
				RETURN
				IF (
				    COUNTROWS( _filter ) = 0,
				    BLANK(),
				    CALCULATE (
				        SELECTEDMEASURE(),
				        'Time Calcs'[Calc] = "Current",
				        _filter
				    )
				)

		calculationItem YOY = ```
				
				VAR _prev = 
