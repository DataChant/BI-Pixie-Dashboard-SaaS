				```

			formatStringDefinition = IF(CALCULATE(SELECTEDMEASURE(), 'Time Calcs'[Calc] = "MOM MTD") = 0, "0%", "#,#.0%")

		calculationItem 'Running Avg 7 Days' = ```
				
				VAR _current_date = MIN('Calendar'[Date])
				RETURN
				AVERAGEX(
				    DATESBETWEEN (
				        'Calendar'[Date],
				        _current_date - 6,
				        _current_date
				    ),
				    CALCULATE (
				        SELECTEDMEASURE(),
				        'Time Calcs'[Calc] = "Current"
				    )
				)           
				```

			formatStringDefinition = "#,0.0"

		calculationItem 'Running Total 7 Days' =
				
				VAR _current_date = MIN('Calendar'[Date])
				RETURN
				SUMX(
				    DATESBETWEEN (
				        'Calendar'[Date],
				        _current_date - 6,
				        _current_date
				    ),
				    CALCULATE (
				        SELECTEDMEASURE(),
				        'Time Calcs'[Calc] = "Current"
				    )
				)

		calculationItem 'Running Avg 30 Days' =
				
				VAR _current_date = MIN('Calendar'[Date])
				RETURN
				AVERAGEX(
				    DATESBETWEEN (
				        'Calendar'[Date],
				        _current_date - 29,
				        _current_date
				    ),
				    CALCULATE (
				        SELECTEDMEASURE(),
				        'Time Calcs'[Calc] = "Current"
				    )
				)

			formatStringDefinition = "#,0.0"

		calculationItem 'Running Total 30 Days' =
				
				VAR _current_date = MIN('Calendar'[Date])
				RETURN
