	measure 'Columns in Visuals Complexity Norm' =
			
			VAR _min = MINX(ALL('Pages'), DIVIDE([Columns in Table Visuals], [Table Visuals]))
			VAR _max = MAXX(ALL('Pages'), DIVIDE([Columns in Table Visuals], [Table Visuals]))
			VAR _current = DIVIDE([Columns in Table Visuals], [Table Visuals])
			RETURN
			IF (
			    ISBLANK(_current) || _current = _min || _max = _min,
			    1,
			    DIVIDE ( _current - _min, _max - _min )
			)
		formatString: #,0.00
		lineageTag: 5db6e200-7436-47c7-9685-ada9e0f7df4f

