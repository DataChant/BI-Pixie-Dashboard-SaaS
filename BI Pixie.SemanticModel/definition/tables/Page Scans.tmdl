table 'Page Scans'
	lineageTag: c83e9501-127a-4e94-83ec-a6a02e2d2d21

	measure Slicers =
			
			VAR _current_date = MAX('Calendar'[Date])
			VAR _max_timestamp_scan =
			    CALCULATE (
			        MAX('Page Scans'[Since]),
			        KEEPFILTERS (
			            'Page Scans'[Date Since] <= _current_date &&
			                ('Page Scans'[Date Until] = BLANK() || 'Page Scans'[Date Until] >= _current_date )
			        )
			    )
			
			RETURN
			SUMX (
			    VALUES('Pages'[Report Page Key]),
			    CALCULATE (
			        MAX('Page Scans'[Slicers Count Col]),
			        KEEPFILTERS ( 'Page Scans'[Since] = _max_timestamp_scan )
			    )
			)
		formatString: #,0
		lineageTag: d9ab1825-2629-4291-83d7-ac4bab459cfa

	measure 'Page Width' = CALCULATE(MAX('Page Scans'[Width]), KEEPFILTERS('Scan Attributes'[Calc] = "Page Attribute"))
		formatString: #,0
		lineageTag: e960c8bd-06c0-4c7e-8ca8-3297c1e8d2f7

	measure 'Page Height' = CALCULATE(MAX('Page Scans'[Height]), KEEPFILTERS('Scan Attributes'[Calc] = "Page Attribute"))
