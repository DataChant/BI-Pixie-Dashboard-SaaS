	partition 'Page Sessions' = m
		mode: import
		source = ```
				let
				    Source = #"Events - Datalake Hierarchy - Base",
				    Custom1 = Table.AddColumn(Source, "Data", each FnLoadPageSessionFromDataLakeFile([Content], [Report Key], [User Key])),
				    #"Removed Columns1" = Table.RemoveColumns(Custom1,{"Content"}),
				    #"Expanded Data" = if #"Is Demo" then  
				        Table.ExpandTableColumn(#"Removed Columns1", "Data", {"User Key", "User sessions index", "FnGetSessions"}, {"User Key.1", "User sessions index", "FnGetSessions"})
				    else
				        Table.ExpandTableColumn(#"Removed Columns1", "Data", {"Project", "Report", "User Key", "User sessions index", "FnGetSessions"}, {"Project.1", "Report.1", "User Key.1", "User sessions index", "FnGetSessions"}),
				    
				    WithDemo = #"Expanded Data",
				    #"Added Custom" = Table.AddColumn(WithDemo, "Report Key.1", each Text.Lower([Project.1]) & "---" & Text.Lower([Report.1])),
				    #"Removed Columns0" = Table.RemoveColumns(#"Added Custom",{"Project", "Report", "Report Key"}),
				    #"Renamed Columns0" = Table.RenameColumns(#"Removed Columns0",{{"Project.1", "Project"}, {"Report.1", "Report"}, {"Report Key.1", "Report Key"}}),
				    WithoutDemo = #"Renamed Columns0",
				    
				    NextStep = if #"Is Demo" then WithDemo else WithoutDemo,
				
				    #"Removed Columns2" = Table.RemoveColumns(NextStep,{"User Key"}),
				    #"Renamed Columns1" = Table.RenameColumns(#"Removed Columns2",{{"User Key.1", "User Key"}}),
				    #"Filtered Rows" = Table.SelectRows(#"Renamed Columns1", each ([User Key] <> null)),
				    #"Expanded FnGetSessions" = Table.ExpandTableColumn(#"Filtered Rows", "FnGetSessions", {"Page", "Page Session Index", "Page Index", "Recalculations", "Slicing Count", "Other Actions", "Tooltip Views", "Session Start", "Session End", "Platform", "Duration (Sec)", "Session Interactions"}, {"Page", "Page Session Index", "Page Index", "Recalculations", "Slicing Count", "Other Actions", "Tooltip Views", "Session Start", "Session End", "Platform", "Duration (Sec)", "Session Interactions"}),
				    #"Changed Type" = Table.TransformColumnTypes(#"Expanded FnGetSessions",{{"Session Interactions", Int64.Type}, {"Slicing Count", Int64.Type}, {"Session Start", type datetime}, {"Session End", type datetime}, {"Duration (Sec)", Int64.Type}, {"Recalculations", Int64.Type}, {"Other Actions", Int64.Type}, {"Tooltip Views", Int64.Type}}),
				    #"Inserted Date" = Table.AddColumn(#"Changed Type", "Date", each DateTime.Date([Session Start]), type date),
				    #"Renamed Columns" = Table.RenameColumns(#"Inserted Date",{{"Date", "Session Start Date"}}),
				    #"Inserted Time" = Table.AddColumn(#"Renamed Columns", "Session Start Time", each DateTime.Time([Session Start]), type time),
				    #"Inserted Merged Column" = Table.AddColumn(#"Inserted Time", "Report Page Key", each Text.Combine({[Report Key], Text.Lower(Text.Trim([Page]))}, "---"), type text),
				    #"Reordered Columns" = Table.ReorderColumns(#"Inserted Merged Column",{"Page", "Report", "Report Page Key", "Page Index", "User Key", "Platform", "Duration (Sec)", "Session Interactions", "Other Actions", "Slicing Count", "Recalculations", "Tooltip Views", "Session Start Date", "Session Start Time", "Session Start", "Session End"}),
				    #"Merged Columns" = Table.CombineColumns(Table.TransformColumnTypes(#"Reordered Columns", {{"User sessions index", type text}, {"Page Session Index", type text}}, "en-US"),{"User sessions index", "Page Session Index"},Combiner.CombineTextByDelimiter("-", QuoteStyle.None),"Page Session Index"),
				    #"Removed Columns" = Table.RemoveColumns(#"Merged Columns",{"Report Key", "Report", "Page", "Project"}),
				    #"Changed Type1" = Table.TransformColumnTypes(#"Removed Columns",{{"Page Index", Int64.Type}})
				in
				    #"Changed Type1"
				```

