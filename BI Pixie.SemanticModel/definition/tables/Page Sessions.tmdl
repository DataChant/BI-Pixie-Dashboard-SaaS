table 'Page Sessions'
	lineageTag: 957f68f0-b395-4673-abb7-18a2b6c91681

	measure 'Avg Duration in Page (Sec)' = AVERAGE('Page Sessions'[Duration (Sec)])
		formatString: #,0
		lineageTag: 1c98c958-b8fa-416e-b2c1-deaf2291deaf

	measure 'Interactive Pages' =
			
			COUNTROWS(FILTER(VALUES('Pages'[Report Page Key]), [Total Interactions Within Page] > 0))
		formatString: #,0
		lineageTag: d787d22e-b16b-42a3-9819-81f17b1b066f

	measure 'Passive Pages' =
			
			COUNTROWS(FILTER(VALUES('Pages'[Report Page Key]), [Total Interactions Within Page] = 0))
		lineageTag: 0f1e2187-1a1d-41e6-afb9-554ebca4aad7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Opened Pages' = ```
			
			DISTINCTCOUNT ( 'Page Sessions'[Report Page Key] )
			
			```
		formatString: #,0
		lineageTag: b0863aeb-0859-4abb-a006-eca3ba2bd3d5

	measure 'Unused Pages' = [Tracked Pages] - [Opened Pages]
		formatString: #,0
		lineageTag: 05d1f72a-92d3-4ba5-8dda-dd70a77c04f5

	measure '% Interactive Pages' = DIVIDE([Interactive Pages], [Tracked Pages])
		formatString: #,0.0%;-#,0.0%;#,0.0%
		lineageTag: 40692c2a-adf4-4a62-a7e5-7684b0e332d1

	measure '% Passive Pages' = DIVIDE([Passive Pages], [Tracked Pages])
		formatString: #,0.0%;-#,0.0%;#,0.0%
		lineageTag: 45c8c703-fc42-4daf-b99e-87a4414b944d

	measure '% Unused Pages' = DIVIDE([Unused Pages], [Tracked Pages])
		formatString: #,0.0%;-#,0.0%;#,0.0%
		lineageTag: 1fa07f11-0e81-4d8d-a4e1-b01b92e2ef35

	measure 'Page Sessions' = ```
			
			COUNTROWS('Page Sessions')
			    
			```
		formatString: #,0
		lineageTag: 1432770e-2e78-4ac5-80b9-86bf12cfa622

	measure 'Total Interactions Within Page' = SUM('Page Sessions'[Session Interactions])
		formatString: #,0
		lineageTag: 78c340b3-8f7f-431b-8efe-59f9103cc8ec

	measure 'Avg Interactions per Session' = AVERAGE('Page Sessions'[Session Interactions])
		formatString: #,0.0
		lineageTag: aa8a7659-f330-4660-9b37-49f8f27193ad

	measure '% Interactive Page Sessions' = DIVIDE ( [Interactive Page Sessions], [Page Sessions] )
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 436dc9f0-1b87-49de-988d-75b35a8143d2

	measure 'Interactive Page Sessions' = CALCULATE([Page Sessions], KEEPFILTERS('Page Sessions'[Session Interactions] > 0))
		formatString: #,0
		lineageTag: 361f0de8-4b54-45c8-8029-b8fc8c8d0abb

	measure 'Passive Page Sessions' = [Page Sessions] - [Interactive Page Sessions]
		formatString: #,0
		lineageTag: ecc2c392-48e6-4071-8143-615426da7df1

	measure 'Slicer Clicks' = SUM('Page Sessions'[Slicing Count])
