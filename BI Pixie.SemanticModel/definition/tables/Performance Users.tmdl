table 'Performance Users'
	lineageTag: f22561c9-fdd6-4de7-a3b7-2cbabbb56ede

	measure 'Performance Value by User' =
			
			IF(
			    SELECTEDVALUE('Performance Stats'[Stat]) = "SUM",
			    SUM('Performance Users'[Value]),
			    DIVIDE(SUM('Performance Users'[Weighted Value]), [Performance Log Count (Users)])
			)
		formatString: #,0.00
		lineageTag: f99815b6-7429-4df3-b995-59e22ffc9301

	measure 'Performance Log Count (Users)' = SUM('Performance Users'[Log Count])
		formatString: #,0
		lineageTag: 8d305a4b-f2ba-4dc4-bf1b-dc09a0ef308a

	measure 'Total CPU Time per Click' =
			
			VAR _clicks = [Clicks in Visual]
			VAR _total_cpu = [Total CPU Time]
			RETURN
			DIVIDE(_total_cpu, _clicks)
		formatString: #,0.00
		lineageTag: 70c06451-7971-4f70-ab11-f157574e995a

	measure 'Total CPU Time' = ```
			
			
			VAR _all_metrics = FILTER(ALL('Performance Metrics'[Metric]), 'Performance Metrics'[Metric] = "Total CPU Time")
			VAR _all_stats = FILTER(ALL('Performance Stats'[Stat]), 'Performance Stats'[Stat] = "SUM")
			
			VAR _total_cpu = 
			CALCULATE(
			    [Performance Value by User],
			    _all_metrics,
			    _all_stats
			)
			RETURN
			_total_cpu
			```
		lineageTag: 0a943580-1dd2-4d05-958f-3a71be1aa87a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Performance Tracked Users' = DISTINCTCOUNT('Performance Users'[User])
		lineageTag: f1a640b3-248c-454a-9ee5-e9146103fda8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Clicks per Second of Total CPU' =
			
			VAR _clicks = [Clicks in Visual]
			VAR _total_cpu = [Total CPU Time]
			RETURN
			DIVIDE(_clicks, _total_cpu)
		lineageTag: 583456c3-881f-41c4-b5a1-9eef5ecd0430

		annotation PBI_FormatHint = {"isGeneralNumber":true}

