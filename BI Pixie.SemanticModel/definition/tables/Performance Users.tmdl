				            "PowerBIWorkspaceId", "PowerBIWorkspaceName", "DatasetId", "ReportId", "RunCount", "TableName",
				            "TotalCpuTimeMs_AVG", "TotalCpuTimeMs_P50", "TotalCpuTimeMs_P75", "TotalCpuTimeMs_P90", "TotalCpuTimeMs_SUM", "User", "role", "VisualId"},
				        {"Consumption Method", "Duration_AVG", "Duration_P50", "Duration_P75", "Duration_P90", "Duration_SUM",
				            "PowerBIWorkspaceId", "PowerBIWorkspaceName", "DatasetId", "ReportId", "Run Count", "TableName",
