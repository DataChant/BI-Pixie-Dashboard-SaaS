	column Mismatch =
			
			VAR _user = 'RLS Events'[User Key]
			VAR _report_page = 'RLS Events'[Report Page Key]
			VAR _session = 'RLS Events'[Session Index]
			VAR _min_mismatch =
			MINX(
			    FILTER(
			        'RLS Events',
			        'RLS Events'[User Key] = _user &&
			        'RLS Events'[Report Page Key] = _report_page &&
			        'RLS Events'[Session Index] = _session
			    ),
			    'RLS Events'[RLS Actual Rows] - 'RLS Events'[RLS Expected Rows]
			)
			RETURN
			IF ( _min_mismatch = 0, 0, 'RLS Events'[RLS Actual Rows] - 'RLS Events'[RLS Expected Rows] )
		isHidden
		formatString: 0
		lineageTag: c96c2b7e-b16d-439d-a9ad-1e1e7bd149ad
		summarizeBy: sum

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

