table 'RLS Events'
	lineageTag: 3406839d-d9f9-46b4-b079-cba3df590329

	measure 'RLS Page Views' =
			
			COUNTROWS (
			    SUMMARIZE('RLS Events', 'RLS Events'[Report Page Key], 'RLS Events'[User Key], 'RLS Events'[Session Index])
			)
		formatString: #,0
		lineageTag: 0752e889-9c42-4e55-9ece-699fa9beb15d

	measure 'RLS Views Single Role Applied' = ```
			
			    [RLS Page Views] - [RLS Views with Unmatched Roles]
			```
		formatString: 0
		lineageTag: b6bce2ea-cc4d-4b18-b9fc-0b1e83bcf523

	measure 'RLS Views with Unmatched Roles' =
			
			COUNTROWS(
			    FILTER (
			        SUMMARIZE (
			            'RLS Events',
			            'RLS Events'[Report Page Key],
			            'RLS Events'[User Key],
			            'RLS Events'[Session Index],
			            'RLS Events'[Date]
			        ),
			        CALCULATE ( MIN ( 'RLS Events'[Mismatch] ) > 0 )
			    )
			)
		formatString: 0
		lineageTag: dbd4f029-fae0-4bf1-a4d9-b42b22a3b5b8

	measure 'RLS Users Unmatched Roles' =
			
			COUNTX (
			    DISTINCT ( 'RLS Events'[User Key] ),
			    [RLS Views with Unmatched Roles]
			)
		formatString: 0
		lineageTag: 0e066b31-0d4b-4fab-84ae-605c40df6658

	measure 'RLS Users' =
			
			COUNTX (
			    Users,
			    [RLS Page Views]
			)
		formatString: 0
		lineageTag: 25497784-7b54-437b-bd2a-c9d6b249266d

	measure 'RLS Users Single Role Applied' =
			
			COUNTX (
			    Users,
			    [RLS Views Single Role Applied]
			)
		formatString: 0
		lineageTag: 20181186-35c4-4afa-b7c9-f6b4c0c64d8c

	measure 'RLS Changes in Allowed Values' =
			
			SUMX (
			    SUMMARIZE (
			        FILTER (
			            'RLS Events',
			            'RLS Events'[Mismatch] = 0
			        ),
			        'RLS Events'[User Key],
			        'RLS Events'[Report Key],
			        'RLS Events'[RLS Role],
			        'RLS Events'[Filtered Table],
			        'RLS Events'[Filtered Column]
			    ),
			    CALCULATE(
			        VAR _distinct_values = DISTINCTCOUNT ( 'RLS Events'[Filtered Values] )
			        RETURN
			        IF ( ISBLANK ( _distinct_values ), BLANK(), _distinct_values - 1 )
			    )
			)
		formatString: 0
		lineageTag: 8172c47f-4e00-46b0-a527-68df2cc6ce8e

	measure 'RLS Views with Over-Blocking' =
			
			CALCULATE (
			    [RLS Page Views],
			    KEEPFILTERS('RLS Events'[Mismatch] = 0 && 'RLS Events'[RLS Actual Rows] = 0)
			)
		formatString: 0
		lineageTag: f65e26d0-d543-4b79-80c7-85ebd7b37c8c

	measure 'RLS Changes in Actual Rows' =
			
			SUMX (
			    SUMMARIZE (
			        FILTER (
			            'RLS Events',
			            'RLS Events'[Mismatch] = 0
			        ),
			        'RLS Events'[User Key],
			        'RLS Events'[Report Key],
			        'RLS Events'[RLS Role],
			        'RLS Events'[Filtered Table]
			    ),
			    CALCULATE(
			        VAR _distinct_values = DISTINCTCOUNT ( 'RLS Events'[RLS Actual Rows] )
			        RETURN
			        IF ( ISBLANK ( _distinct_values ), BLANK(), _distinct_values - 1 )
			    )
			)
		formatString: 0
		lineageTag: a22a8490-f9b8-49fa-9026-ee342c4cbff0

	measure 'RLS Events' = COUNTROWS ( 'RLS Events' )
		lineageTag: d45a94c1-a2e2-495c-8a0e-ebbd13b93db2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'RLS Changes' =
			
			VAR _results = [RLS Changes in Actual Rows] + [RLS Changes in Allowed Values]
			RETURN
			IF (_results = 0, BLANK(), _results)
		formatString: 0
		lineageTag: 819dcfdc-418f-4cf5-b0d8-fb75b4da1be9

	measure 'RLS Users Suspicious Changes' =
			
			COUNTX (
			    Users,
			    [RLS Changes]
			)
		formatString: 0
		lineageTag: 8458df18-9358-450b-8190-fec7db7cb1d0

	measure 'RLS Users Overblocked' =
			
			COUNTX (
			    Users,
			    [RLS Views with Over-Blocking]
			)
		formatString: 0
		lineageTag: fe64f8a0-a21e-4153-9339-77f998002848

	measure 'RLS Max Distinct Count' = MAX('RLS Events'[Filtered Distinct Count])
		formatString: #,0
		lineageTag: 115de1bf-4b79-43c8-b4ad-1e3a49248d78

	measure 'RLS Loaded Rows' =
			
			SUMX (
			    SUMMARIZE (
			        FILTER (
			            'RLS Events',
			            'RLS Events'[Mismatch] > 0
			        ),
			        'RLS Events'[Report Page Key],
			        'RLS Events'[User Key],
			        'RLS Events'[RLS Role],
			        'RLS Events'[Filtered Table]
			    ),
			    CALCULATE (
			        AVERAGE( 'RLS Events'[RLS Actual Rows] )
			    )
			)
		formatString: #,0
		lineageTag: 48795961-8ce2-4a37-9a74-37359e1c51a0

	measure 'Expected Filtered Rows' =
			
			SUMX (
			    SUMMARIZE (
			        FILTER (
			            'RLS Events',
			            'RLS Events'[Mismatch] > 0
			        ),
			        'RLS Events'[Report Page Key],
			        'RLS Events'[User Key],
			        'RLS Events'[RLS Role],
			        'RLS Events'[Filtered Table]
			    ),
			    CALCULATE (
			        AVERAGE( 'RLS Events'[RLS Expected Rows] )
			    )
			)
		formatString: #,0
		lineageTag: dc6d2d4a-58d4-4f9d-94d1-d1f6eca9db7a

	measure 'Suspected Overexposed Rows' = [RLS Loaded Rows] - [Expected Filtered Rows]
		formatString: #,0
		lineageTag: 3e4010c1-0781-4353-8a88-bf46f8e4f32f

	measure 'RLS Last Date' = LASTDATE( 'RLS Events'[Date] )
		lineageTag: 144e55b4-b732-4334-bafe-05b99d6c995b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'RLS Loaded Rows (Average)' =
			
			AVERAGEX(
			    SUMMARIZE (
			        'RLS Events',
			        'RLS Events'[Report Page Key],
			        'RLS Events'[User Key],
			        'RLS Events'[RLS Role],
			        'RLS Events'[Filtered Table]
			    ),
			    CALCULATE (
			        AVERAGE( 'RLS Events'[RLS Actual Rows] )
			    )
			)
		formatString: #,0
		lineageTag: 15ce79c5-e294-4b09-894e-5d00a46174b2

