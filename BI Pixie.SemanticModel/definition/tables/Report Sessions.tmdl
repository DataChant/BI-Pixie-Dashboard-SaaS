	column 'Pages Interaction Count' =
			VAR _session_id = 'Report Sessions'[Session Index]
			RETURN
			CALCULATE (
			    SUM ( 'Page Sessions'[Session Interactions] ),
			    FILTER ( 'Session Indices', 'Session Indices'[Session Index] = _session_id )
			)
		isHidden
		formatString: 0
		lineageTag: b227f108-c62e-4977-80d4-8e728cb5b4de
