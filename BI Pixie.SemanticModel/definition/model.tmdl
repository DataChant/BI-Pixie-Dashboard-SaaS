	annotation PBI_QueryGroupOrder = 9

queryGroup 'Visual Types'

	annotation PBI_QueryGroupOrder = 10

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["FnLoadDatalakeFile","FnLoadInventory","FnGetReportRawSessions","FnCountSlicerEventsInner","FnCountSlicerEvents","FnGetPageSessions","FnGetSessions","All Visual Types","Capacities","Capacity-Unknown","Clicks by Visual","Data Selections","Deployment Pipelines","Event Types","Export Metrics","Events","Feedback","Feedback Icons","Feedback Type","Inventory Scans","License","Page Scans","Pages","Page Sessions","Platforms","Report Sessions","Page Sessions - Test","Report Scans","Survey","Survey Questions","Time","Visual Attributes Options","Visual Scans","Visual Trust Levels","Visuals","Workspaces","Visual Types","FnSessionizeRLSEvents","RLS Events Demo","RLS Events","Data Lake URL","License Key","FnLoadReportSessionFromDataLakeFile","FnLoadPageSessionFromDataLakeFile","Events - Datalake Base","Events - Base","Projects and Reports - Base","Events - Datalake Hierarchy - Base","Data Selection Events","Data Selections - Base","Report Sessions - Base","Inventory - Base 0","Inventory - Reports - Base 1","Inventory - Reports - Base 2","Inventory - Reports - Base 3","Workspace-Unknown","Workspaces - Base","Are Users Anonymous","Last N Days","Session timeout (min)","Inventory - Pages - Base 1","Inventory - Report IDs - Demo","FnPrepareSCD","Internal Users - Base","External Users","Managers","Internal Users","Internal Users - Empty","External Users - Empty","Feedback - Base","Is Demo","Instrumentation Activities","Built In Visuals","Custom Visuals","Unlisted Visuals","Unknown Visuals","Visual Type Fix","EmptyUnkownVisualTypes","UncertifiedDemo","Is SaaS","Reports"]

