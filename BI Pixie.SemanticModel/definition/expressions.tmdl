		        {"Created On", "License Key", "Project", "Report", "Page", "Event Type", "Username", "Bookmark", "Link", "Visual Name", "Visual Type", "Filtered Column", "Filtered Distinct Count", "Filtered Values", "Client IP", "User-Agent", "Page Index", "Line Id", "Feedback"}}
		    ),
		    #"Renamed Zip Fields" = Table.RenameColumns(#"Changed Type",RenamedFields),
		    #"Added User Key" = Table.AddColumn(#"Renamed Zip Fields", "User Key", each if #"Are Users Anonymous" then [Client IP] else if #"Is Demo" then userKey else [Username]),
		    #"Added Platform" = Table.AddColumn(#"Added User Key", "Platform", each if [User Key] <> null and not Text.Contains([User Key], "@") then "Desktop" else if [#"User-Agent"] <> null and Text.Contains([#"User-Agent"], "PBIMobile") then "Mobile App" else if [#"User-Agent"] <> null and Text.Contains([#"User-Agent"], "Mobile") then "Mobile" else "Web"),
		    #"Added Report Page Key" =
		        if #"Is Demo" then
		            Table.AddColumn(#"Added Platform", "Report Page Key", each Text.Combine({reportKey, Text.Lower(Text.Trim([Page]))}, "---"), type text)
		        else
		            Table.AddColumn(#"Added Platform", "Report Page Key", each Text.Combine({Text.Lower(Text.Trim([Project])), Text.Lower(Text.Trim([Report])), Text.Lower(Text.Trim([Page]))}, "---"), type text),
		    
		    #"Changed Type1" = Table.TransformColumnTypes(#"Added Report Page Key",{{"Created On", type datetime}, {"Page Index", Int64.Type}}),
		
		    #"Inserted Date" = Table.AddColumn(#"Changed Type1", "Date", each DateTime.Date([Created On]), type date),
		    #"Inserted Time" = Table.AddColumn(#"Inserted Date", "Time", each DateTime.Time([Created On]), type time),
		    events = Table.ReplaceValue(#"Inserted Time",null,1,Replacer.ReplaceValue,{"Page Index"}),
		    #"Duplicated Column" = Table.DuplicateColumn(events, "Platform", "Platform - Key"),
		    #"Replaced Value1" = Table.ReplaceValue(#"Duplicated Column","Mobile App","Mobile",Replacer.ReplaceText,{"Platform - Key"}),
		    //#"Filtered Rows" = Table.SelectRows(#"Replaced Value1", each ([Event Type] <> "Inventory" and [Event Type] <> "VizClick")),
		    #"Filtered Rows" = Table.SelectRows(#"Replaced Value1", each ([Event Type] <> "Inventory")),
		    
		    #"Grouped Rows" = Table.Group(#"Filtered Rows", {"Project", "Report", "User Key", "Platform - Key"}, {{"Events", each _, type table [Created On=nullable datetime, Event Type=nullable text, Report=nullable text, Page=nullable text, Page Index=nullable number, Link=nullable text, Bookmark=nullable text, Visual Type=nullable text, Visual Name=nullable text, Filtered Column=nullable text, Filtered Values=nullable text, Filtered Distinct Count=nullable number, Username=nullable text, User Key=text, Client IP=nullable text, Platform=text, #"User-Agent"=nullable text, Index=nullable number, Date=date, Time=time, Report Page Key=text, #"Platform - Key"=nullable text]}}),
		    #"Added Index" = Table.AddIndexColumn(#"Grouped Rows", "User sessions index", 0, 1, Int64.Type),
		
		
		    //Test function: FnGetReportRawSessions
		    UserSessions = #"Filtered Rows",
		    
		    #"Sorted Rows" = Table.Sort(UserSessions,{{"Created On", Order.Ascending}}),
		    #"Removed Columns" = Table.RemoveColumns(#"Sorted Rows",{"User Key", "Report"}),
		    #"Added Log Index" = Table.AddIndexColumn(#"Removed Columns", "Index", 0, 1, Int64.Type),
		    Buffered = Table.Buffer(#"Added Log Index"),
		    #"Added Previous Created On" = Table.AddColumn(Buffered, "Previous timestamp", each try Buffered{[Index]-1}[Created On] otherwise [Created On]),
		    #"Changed Timestamp Type" = Table.TransformColumnTypes(#"Added Previous Created On",{{"Previous timestamp", type datetime}}),
		    #"Inserted Time Subtraction" = Table.AddColumn(#"Changed Timestamp Type", "Minutes since last", each [Created On] - [Previous timestamp], type duration),
		    #"Calculated Total Minutes" = Table.TransformColumns(#"Inserted Time Subtraction",{{"Minutes since last", Duration.TotalMinutes, type number}}),
		    #"Add Previous Page" = Table.AddColumn(#"Calculated Total Minutes", "Previous page", each try #"Calculated Total Minutes"{[Index]-1}[Page] otherwise [Page]),
		    #"Add Second Previous Page" = Table.AddColumn(#"Add Previous Page", "Second previous page", each try #"Add Previous Page"{[Index]-2}[Page] otherwise [Page]),
		    #"Add Previous Event" = Table.AddColumn(#"Add Second Previous Page", "Previous event", each try #"Add Second Previous Page"{[Index]-1}[Event Type] otherwise [Event Type]),
		    #"Added Updated Page" = Table.AddColumn(#"Add Previous Event", "Updated page", each if ([Event Type] = "Bookmark" or [Event Type] = "Tooltip" or [Event Type] = "Drillthru") and [Page] <> [Previous page] then [Previous page] else [Page]),
		    #"Renamed Columns2" = Table.RenameColumns(#"Added Updated Page",{{"Page", "Original page"}, {"Updated page", "Page"}}),
		    #"Added Page Session Index" = Table.AddColumn( #"Renamed Columns2", "Page Session Index",
		        each if [Index] = 0 then 0 else if [Minutes since last] > #"Session timeout (min)" then [Index]
		        else if ([Previous event] = "Bookmark" or [Previous event] = "Tooltip" or [Previous event] = "Drillthru") and ([Second previous page] <> [Previous page]) then [Index] else null),
		    
		    
		    #"Removed Columns2" = Table.RemoveColumns(#"Added Page Session Index",{"Original page", "Previous page", "Previous event", "Second previous page"}),
		    #"Filled Down" = Table.FillDown(#"Removed Columns2",{"Page Session Index"}),
		    AddedSessionIndex = Table.AddColumn(#"Filled Down", "Session Index", each if [Minutes since last] > #"Session timeout (min)" then [Index] else if [Index] = 0 then 0 else null),
		    AddedPlatformNew = Table.AddColumn(AddedSessionIndex, "Platform New", each if [Session Index] = null then null else [Platform]),
		    FilledDown = Table.FillDown(AddedPlatformNew,{"Session Index", "Platform New"}),
		    #"Replaced Value" = Table.ReplaceValue(FilledDown,null,0,Replacer.ReplaceValue,{"Session Index"}),
		    RemovedIndexColumns = Table.RemoveColumns(#"Replaced Value",{"Index"}),
		    //End Test function: FnGetReportRawSessions
		    // Test FnGetPageSessions
		    reportSession = RemovedIndexColumns,
		    #"Grouped Rows1" = Table.Group(reportSession, {"Page", "Page Session Index"}, {
		        {"Recalculations", each List.Max({0, -1 + List.NonNullCount(List.Select([Event Type], each _ = "Sense"))}), Int16.Type},
		        {"Slicing Count", each FnCountSlicerEvents(_), Int16.Type},
		        {"Other Actions", each List.NonNullCount(List.Select([Event Type], each _ <> "Sense" and _ <> "Slicer" and _ <> "Filter" and _<> "Page" and _<> "Tooltip" and _ <> "VizClick" and _<> "RLS")), Int16.Type },
		        {"Tooltip Views", each List.Count(List.Select([Event Type], each _ = "Tooltip")), Int16.Type},
		        {"Session Start", each List.Min([Created On]), type nullable datetime},
		        {"Session End", each List.Max([Created On]), type nullable datetime},
		        {"Platform", each List.First([Platform New]), Text.Type},
		        {"Raw", each _, Table.Type}
		    }),
		    #"Inserted Time Subtraction1" = Table.AddColumn(#"Grouped Rows1", "Duration (Sec)", each [Session End] - [Session Start], type duration),
		    #"Calculated Total Seconds" = Table.TransformColumns(#"Inserted Time Subtraction1",{{"Duration (Sec)", each Duration.TotalSeconds(_), type number}}),
		    #"Added Custom" = Table.AddColumn(#"Calculated Total Seconds", "Session Interactions", each [Tooltip Views] + [Other Actions] + List.Max({[Recalculations], [Slicing Count]})),
		    #"Changed Session Interactions Type" = Table.TransformColumnTypes(#"Added Custom",{{"Session Interactions", Int64.Type}})
		in
		    #"Changed Session Interactions Type"
		```
