		    TableBuf = Table.Buffer(#"Inserted Date Subtraction"),
		    #"Sorted Rows" = Table.Sort(TableBuf, {{"Subtraction", Order.Ascending}}),
		    Results = if Table.RowCount(#"Sorted Rows") > 0 then #"Sorted Rows"{0} else null
		in
		    Results
