expression 'PBI Reports - Base' = ```
		let
		    Source = #"PBI Workspaces Reports - Base",
		    #"Added Conditional Column" = Table.AddColumn(Source, "Report Type2", each if Text.StartsWith([Report Name], "[App] ") then "App Report" else [Report Type]),
		    Custom1 = Table.AddColumn(#"Added Conditional Column", "Report Name2", each if [Report Type2] <> "App Report" then [Report Name] else Text.ReplaceRange([Report Name], 0, 6, "")),
		    #"Removed Columns" = Table.RemoveColumns(Custom1,{"Report Name","Report Type"}),
		    #"Renamed Columns1" = Table.RenameColumns(#"Removed Columns",{{"Report Name2", "Report Name"}, {"Report Type2", "Report Type"}}),
		    LastNonDemo = Table.AddColumn(#"Renamed Columns1", "Report Key", each Text.Lower(Text.Combine({[Workspace Name], [Report Name]}, "---")), type text),
		
		    FirstDemoStep = LastNonDemo,
		    #"Filtered Rows" = Table.SelectRows(FirstDemoStep, each ([Workspace Name] = "BI Pixie Demo" or [Workspace Name] = "Demo Workspace 1" or [Workspace Name] = "Demo Workspace 2" or [Workspace Name] = "Demo Workspace 3" or [Workspace Name] = "Demos" or [Workspace Name] = "Workspace 2")),
		    #"Added Index" = Table.AddIndexColumn(#"Filtered Rows", "Index", 1, 1, Int64.Type),
		    #"Inserted Modulo" = Table.AddColumn(#"Added Index", "Modulo", each 1+ Number.Mod([Index], 23), type number),
		    
		    #"Merged Queries" = Table.NestedJoin(#"Inserted Modulo", {"Modulo"}, #"Users Demo", {"Index"}, "Users Demo", JoinKind.LeftOuter),
		    #"Expanded Users Demo" = Table.ExpandTableColumn(#"Merged Queries", "Users Demo", {"User Key"}, {"User Key"}),
		    #"Duplicated Column" = Table.DuplicateColumn(#"Expanded Users Demo", "User Key", "User Key - Copy"),
		    #"Removed Columns1" = Table.RemoveColumns(#"Duplicated Column",{"Modified By", "Created By", "Modulo"}),
		    #"Renamed Columns" = Table.RenameColumns(#"Removed Columns1",{{"User Key", "Modified By"}, {"User Key - Copy", "Created By"}}),
		
		    #"Inserted Modulo1" = Table.AddColumn(#"Renamed Columns", "Modulo", each Number.Mod([Index], 6), type number),
		    #"Changed Type1" = Table.TransformColumnTypes(#"Inserted Modulo1",{{"Modulo", type text}}),
		    #"Merged Queries1" = Table.NestedJoin(#"Changed Type1", {"Modulo"}, #"Dataset Endorsement Types", {"Order"}, "Dataset Endorsement Types", JoinKind.LeftOuter),
		    #"Expanded Dataset Endorsement Types" = Table.ExpandTableColumn(#"Merged Queries1", "Dataset Endorsement Types", {"Endorsement"}, {"Endorsement.1"}),
		    #"Replaced Value1" = Table.ReplaceValue(#"Expanded Dataset Endorsement Types",null,"None",Replacer.ReplaceValue,{"Endorsement.1"}),
		    #"Removed Columns3" = Table.RemoveColumns(#"Replaced Value1",{"Endorsement"}),
		    #"Renamed Columns2" = Table.RenameColumns(#"Removed Columns3",{{"Endorsement.1", "Endorsement"}}),
		    #"Removed Columns2" = Table.RemoveColumns(#"Renamed Columns2",{"Modulo", "Index"}),
		    LastDemo = #"Removed Columns2",
		    
		    Final = if #"Is Demo" then LastDemo else LastNonDemo
		in
		    Final
		```
