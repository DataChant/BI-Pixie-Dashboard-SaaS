expression 'Sample Export Events' =
		let
		    Source = Json.Document(#"Sample Log Analytics Content"),
		    #"Converted to Table" = Table.FromList(Source, Splitter.SplitByNothing(), null, null, ExtraValues.Error),
		    #"Expanded Column1" = Table.ExpandRecordColumn(#"Converted to Table", "Column1", {"TimeGenerated", "ApplicationName", "PowerBIWorkspaceId", "DAXQueryNormalized", "User", "roles", "DatasetId", "ReportId", "VisualId", "TableColumns", "QueryResultRows", "DurationMs", "VertipaqJobCpuTimeMs", "QueryProcessingCpuTimeMs", "TotalCpuTimeMs", "ExecutionDelayMs", "ApproximatePeakMemConsumptionKB"}, {"TimeGenerated", "ApplicationName", "PowerBIWorkspaceId", "DAXQueryNormalized", "User", "Roles", "DatasetId", "ReportId", "VisualId", "TableColumns", "QueryResultRows", "DurationMs", "VertipaqJobCpuTimeMs", "QueryProcessingCpuTimeMs", "TotalCpuTimeMs", "ExecutionDelayMs", "ApproximatePeakMemConsumptionKB"}),
		    #"Changed Type" = Table.TransformColumnTypes(#"Expanded Column1",{{"TimeGenerated", type datetimezone}, {"User", type text}, {"DatasetId", type text}, {"ReportId", type text}, {"VisualId", type text}, {"QueryResultRows", type text}, {"VertipaqJobCpuTimeMs", Int64.Type}, {"QueryProcessingCpuTimeMs", Int64.Type}, {"TotalCpuTimeMs", Int64.Type}, {"ExecutionDelayMs", Int64.Type}, {"ApproximatePeakMemConsumptionKB", Int64.Type}, {"TableColumns", type text}}),
		    #"Split Column by Delimiter" = Table.SplitColumn(#"Changed Type", "DAXQueryNormalized", Splitter.SplitTextByEachDelimiter({"[WaitTime:"}, QuoteStyle.Csv, true), {"DAXQuery"}),
		    #"Filtered Rows" = Table.SelectRows(#"Split Column by Delimiter", each [VisualId] = "" or [VisualId] = null),
		    #"Added Conditional Column" = Table.AddColumn(#"Filtered Rows", "Custom", each
		        if Text.Contains([DAXQuery], "__DS0BodyLimited = TOPN( 500000,") then [#"Max Rows" = 500000, #"Export Type" = "Excel Live Connection"]
		        else if Text.Contains([DAXQuery], "__DS0BodyLimited = TOPN(150002,") then [#"Max Rows" = 150000, #"Export Type" = "Excel Export"]
		        else if Text.Contains([DAXQuery], "__DS0BodyLimited = TOPN( 150002,") then [#"Max Rows" = 150000, #"Export Type" = "Excel Export"]
		        else if Text.Contains([DAXQuery], "__DS0BodyLimited = TOPN( 30002") then [#"Max Rows" = 30000, #"Export Type" = "CSV Export"]
		        else if Text.Contains([DAXQuery], "__DS0PrimaryWindowed = TOPN( 501, FILTER( KEEPFILTERS(__DS0Core), ISONORAFTER(") then [#"Max Rows" = 500, #"Export Type" = "Scroll Down"]
		        else if Text.Contains([DAXQuery], "__DS0PrimaryWindowed = TOPN( 101") and Text.Contains([DAXQuery], ", ISONORAFTER(") then [#"Max Rows" = 100, #"Export Type" = "Scroll Down"]
		        else [#"Max Rows" = null, #"Export Type" = null]),
		    #"Expanded Custom" = Table.ExpandRecordColumn(#"Added Conditional Column", "Custom", {"Max Rows", "Export Type"}, {"Max Rows", "Export Type"}),
		    #"Filtered Rows1" = Table.SelectRows(#"Expanded Custom", each [Max Rows] <> null and [Max Rows] <> ""),
		    #"Trimmed Text" = Table.TransformColumns(#"Filtered Rows1",{{"DAXQuery", Text.Trim, type text}}),
		    #"Lowercased Text" = Table.TransformColumns(#"Trimmed Text",{{"PowerBIWorkspaceId", Text.Lower, type text}})
		in
		    #"Lowercased Text"
	lineageTag: 5d4b4393-333b-4d5d-af13-c80ec392856e
