	column 'Duration (Sec)'
		isHidden
		formatString: 0
		lineageTag: 4fe3881c-2535-4c88-8652-3782e14df740
		summarizeBy: none
		sourceColumn: [Value]

		annotation SummarizationSetBy = Automatic

	column 'Duration Set' =
			SWITCH (
			    TRUE(),
			    'Durations X'[Duration (Sec)] <= 1, "1s",
			    'Durations X'[Duration (Sec)] <= 5, "<= 5s",
			    'Durations X'[Duration (Sec)] <= 10, "<= 10s",
			    'Durations X'[Duration (Sec)] <= 15, "<= 15s",
			    'Durations X'[Duration (Sec)] <= 20, "<= 20s",
			    'Durations X'[Duration (Sec)] <= 30, "<= 30s",
			    'Durations X'[Duration (Sec)] <= 50, "<= 50s",
			    'Durations X'[Duration (Sec)] <= 60, "<= 1m",
			    "<= " & ROUNDUP(DIVIDE('Durations X'[Duration (Sec)], 60), 0) & "m"
			)
		lineageTag: 0eda34c7-93bc-4b81-8819-9d7d54296568
		summarizeBy: none
		sortByColumn: 'Duration Set Val'

		annotation SummarizationSetBy = Automatic

	column 'Duration Set Val' =
			SWITCH (
			    TRUE(),
			    'Durations X'[Duration (Sec)] <= 1, 1,
			    'Durations X'[Duration (Sec)] <= 5, 5,
			    'Durations X'[Duration (Sec)] <= 10, 10,
			    'Durations X'[Duration (Sec)] <= 15, 15,
			    'Durations X'[Duration (Sec)] <= 20, 20,
			    'Durations X'[Duration (Sec)] <= 30, 30,
			    'Durations X'[Duration (Sec)] <= 50, 50,
			    'Durations X'[Duration (Sec)] <= 60, 60,
			    60 * ROUNDUP(DIVIDE('Durations X'[Duration (Sec)], 60), 0)
			)
		lineageTag: 61185b89-2b7f-48b3-9385-8cc7d8d048a8
		summarizeBy: sum

