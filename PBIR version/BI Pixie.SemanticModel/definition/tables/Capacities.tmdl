				    #"Removed Duplicates" = Table.Distinct(#"Sorted Rows", {"Capacity ID"}),
				    #"Removed Columns2" = Table.RemoveColumns(#"Removed Duplicates",{"Since"}),
				    #"Appended Query" = Table.Combine({#"Removed Columns2", #"Capacity-Unknown"}),
				    #"Added Custom" = Table.AddColumn(#"Appended Query", "SKU and Capacity Name", each "(" & [SKU] & ") " & [Capacity Name]),
				    #"Replaced Value" = Table.ReplaceValue(#"Added Custom","(Unknown) ","",Replacer.ReplaceText,{"SKU and Capacity Name"}),
				    LastNonDemo = Table.ReplaceValue(#"Replaced Value","(Power BI Pro) ","",Replacer.ReplaceText,{"SKU and Capacity Name"}),
				    
				    #"Replaced Value2" = Table.ReplaceValue(LastNonDemo,"(FT1) Trial-20231210T183548Z-eEDgkCJMPEaeAeUSYzQdig","(F128) f128fabric",Replacer.ReplaceText,{"SKU and Capacity Name"}),
				    #"Replaced Value3" = Table.ReplaceValue(#"Replaced Value2","FT1","F128",Replacer.ReplaceText,{"SKU"}),
				    LastDemo = Table.ReplaceValue(#"Replaced Value3","Trial-20231210T183548Z-eEDgkCJMPEaeAeUSYzQdig","f128fabric",Replacer.ReplaceText,{"Capacity Name"}),
				    Final = if not #"Is Demo" then LastNonDemo else LastDemo
				in
				    Final
				```

