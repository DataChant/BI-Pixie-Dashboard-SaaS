				    #"Expanded capacities" = Table.ExpandListColumn(#"Filtered Rows2", "capacities"),
				    #"Expanded capacities1" = Table.ExpandRecordColumn(#"Expanded capacities", "capacities", {"id", "displayName", "sku", "region", "state"}, {"Capacity ID", "Capacity Name", "SKU", "Region", "State"}),
				    #"Filtered Rows1" = Table.SelectRows(#"Expanded capacities1", each [Capacity ID] <> null and [Capacity ID] <> ""),
				    #"Renamed Columns" = Table.RenameColumns(#"Filtered Rows1",{{"Date modified", "Since"}}),
