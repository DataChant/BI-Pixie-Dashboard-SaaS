	measure 'Clicks Crossfiltered by Heatmap' =
			
			VAR _isXFiltered = ISFILTERED('X Dimension2'[X])
			VAR _isXCrossFiltered = ISCROSSFILTERED('X Dimension2'[X])
			RETURN
			IF (
			    NOT(_isXCrossFiltered || _isXFiltered),
			    [Clicks in Visual],
			    [Clicks in Heatmap]
			)
		formatString: 0
		lineageTag: fd25bbc4-50b0-4673-9df6-e4e0065e085a

	measure 'Clicks Crossfiltered by Heatmap and Column' = ```
			
			VAR _isXFiltered = ISFILTERED('X Dimension2'[X])
			VAR _isXCrossFiltered = ISCROSSFILTERED('X Dimension2'[X])
			
			RETURN
			IF (
			    NOT(_isXCrossFiltered || _isXFiltered),
			    [Click Events],
			    VAR _x_current = MAX('X Dimension2'[X])
			    VAR _y_current = MAX('Y Dimension2'[Y])
			    VAR _filtered_visuals =
			    CALCULATETABLE (
			        VALUES('Clicks by Visual'[Visual Key]),
			        VAR _x_cell_size = [X Heatmap Cell Size2]
			        VAR _y_cell_size = [Y Heatmap Cell Size2]
			        VAR _x = _x_current * _x_cell_size
			        VAR _y = _y_current * _y_cell_size
			        RETURN
			        FILTER (
			            Visuals,
			            Visuals[X] < _x && Visuals[X] + Visuals[Width] > _x + _x_cell_size &&
			            Visuals[Y] < _y && Visuals[Y] + Visuals[Height] > _y + _y_cell_size
			        )
			    )
			    VAR _clicks = 
			    CALCULATE (
			        [Click Events],
			        _filtered_visuals
			    )
			    RETURN
			    _clicks
			)
			```
		formatString: #,0
