	measure 'Scanned visuals' = DISTINCTCOUNT('Visual Scans'[Visual Key])
		lineageTag: 56d92dde-7358-4dfc-8f4a-ad8c2368cb3f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Heatmap Visual Border' = ```
			
			VAR _x_cell_size = [X Heatmap Cell Size2]
			VAR _y_cell_size = [Y Heatmap Cell Size2]
			VAR _x = MAX('X Dimension2'[X]) * _x_cell_size
			VAR _y = MAX('Y Dimension2'[Y]) * _y_cell_size
			VAR _pages = DISTINCTCOUNT('Visuals'[Report Page Key])
			VAR _visuals_in_cell = 
			CALCULATE ( 
			    COUNTROWS(Visuals),
			    KEEPFILTERS (
			        'Visuals'[X] <= _x + _x_cell_size && 'Visuals'[X] + 'Visuals'[Width] >= _x &&
			        'Visuals'[Y] <= _y + _y_cell_size && 'Visuals'[Y] + 'Visuals'[Height] >= _y
			    )
			)
			
			VAR _visuals_above_end_here = 
			CALCULATE (
			    COUNTROWS(Visuals),
			    KEEPFILTERS (
			        'Visuals'[Y] + 'Visuals'[Height] >= _y && 'Visuals'[Y] + 'Visuals'[Height] <= _y + _y_cell_size &&
			        'Visuals'[X] <= _x + _x_cell_size && 'Visuals'[X] + 'Visuals'[Width] >= _x
			    )
			)
			
			VAR _visuals_below_start_here = 
			CALCULATE (
			    COUNTROWS('Visuals'),
			    KEEPFILTERS (
			        'Visuals'[Y] >= _y && 'Visuals'[Y] <= _y + _y_cell_size &&
			        'Visuals'[X] <= _x + _x_cell_size && 'Visuals'[X] + 'Visuals'[Width] >= _x
			    )
			)
			
			VAR _left_visuals_end_here = 
			CALCULATE (
			    COUNTROWS('Visuals'),
			    KEEPFILTERS(
			        'Visuals'[X] + 'Visuals'[Width] >= _x && 'Visuals'[X] + 'Visuals'[Width] <= _x + _x_cell_size &&
			        'Visuals'[Y] <= _y + _y_cell_size &&  'Visuals'[Y] + 'Visuals'[Height] >= _y
			    )
			)
			
			VAR _right_visuals_start_here =
			CALCULATE (
			    COUNTROWS ('Visuals'),
			    KEEPFILTERS (
			        'Visuals'[X] >= _x && Visuals[X] <= _x + _x_cell_size &&
			        'Visuals'[Y] <= _y + _y_cell_size && 'Visuals'[Y] + 'Visuals'[Height] >= _y
			    )
			)
			
			VAR _visuals_with_top_left_corner = 
			    CALCULATE (
			        COUNTROWS ('Visuals'),
			        KEEPFILTERS (
			            'Visuals'[X] >= _x && 'Visuals'[X] <= _x + _x_cell_size &&
			            'Visuals'[Y] >= _y && 'Visuals'[Y] <= _y + _y_cell_size
			        )
			    )
			
			VAR _visuals_with_top_right_corner = 
			CALCULATE (
			    COUNTROWS ('Visuals'),
			    KEEPFILTERS (
			        'Visuals'[X] + 'Visuals'[Width] >= _x && 'Visuals'[X] + 'Visuals'[Width] <= _x + _x_cell_size &&
			        'Visuals'[Y] >= _y && 'Visuals'[Y] <= _y + _y_cell_size
			    )
			)
			
			VAR _visuals_with_bottom_left_corner = 
			CALCULATE (
			    COUNTROWS ('Visuals'),
			        KEEPFILTERS (
			        'Visuals'[X] >= _x && 'Visuals'[X] <= _x + _x_cell_size &&
			        'Visuals'[Y] + 'Visuals'[Height] >= _y && 'Visuals'[Y] + 'Visuals'[Height] <= _y + _y_cell_size
			    )
			)
			
			VAR _visuals_with_bottom_right_corner = 
			CALCULATE (
			    COUNTROWS ('Visuals'),
			        KEEPFILTERS (
			        'Visuals'[X] + 'Visuals'[Width] >= _x && 'Visuals'[X] + 'Visuals'[Width] <= _x + _x_cell_size &&
			        'Visuals'[Y] + 'Visuals'[Height] >= _y && 'Visuals'[Y] + 'Visuals'[Height] <= _y + _y_cell_size
			    )
			)
			
			RETURN
			SWITCH (
			    TRUE (),
			    _pages > 1 || ISBLANK(_visuals_in_cell), " ",
			    (_visuals_with_top_left_corner > 0 && _visuals_with_bottom_right_corner > 0) || (_visuals_with_top_right_corner > 0 && _visuals_with_bottom_left_corner > 0), "╋",
			    
			    _visuals_above_end_here > 0 && _visuals_with_bottom_left_corner = 0 &&  _visuals_with_bottom_right_corner = 0  && (_visuals_with_top_left_corner > 0 || _visuals_with_top_right_corner > 0), "┳",
			    _visuals_with_top_left_corner > 0 && _visuals_with_top_right_corner > 0 && _visuals_with_bottom_left_corner = 0 && _visuals_with_bottom_right_corner = 0, "┳",
			    
			    _visuals_below_start_here > 0 && _visuals_with_top_right_corner = 0 && _visuals_with_top_left_corner = 0 && (_visuals_with_bottom_left_corner > 0 || _visuals_with_bottom_right_corner > 0), "┷",
			    _visuals_with_top_left_corner = 0 && _visuals_with_top_right_corner = 0 && _visuals_with_bottom_left_corner > 0 && _visuals_with_bottom_right_corner > 0, "┷", 
			    
			    _right_visuals_start_here > 0 && _visuals_with_bottom_left_corner = 0 &&  _visuals_with_top_left_corner = 0 && (_visuals_with_bottom_right_corner > 0 || _visuals_with_top_right_corner > 0), "┫",
			    _visuals_with_top_left_corner = 0 && _visuals_with_top_right_corner > 0 && _visuals_with_bottom_left_corner = 0 && _visuals_with_bottom_right_corner > 0, "┫",
			    
			    _left_visuals_end_here > 0 && _visuals_with_top_right_corner = 0 && _visuals_with_bottom_right_corner = 0 && (_visuals_with_bottom_left_corner > 0 || _visuals_with_top_left_corner > 0), "┣",
			    _visuals_with_top_left_corner > 0 && _visuals_with_top_right_corner = 0 && _visuals_with_bottom_left_corner > 0 && _visuals_with_bottom_right_corner = 0, "┣", 
			
			    _visuals_with_top_left_corner = 0 && _visuals_with_top_right_corner = 0 && _visuals_with_bottom_left_corner = 0 && _visuals_with_bottom_right_corner > 0, "┛",
			    _visuals_with_top_left_corner = 0 && _visuals_with_top_right_corner = 0 && _visuals_with_bottom_left_corner > 0 && _visuals_with_bottom_right_corner = 0, "┗",
			    _visuals_with_top_left_corner > 0 && _visuals_with_top_right_corner = 0 && _visuals_with_bottom_left_corner = 0 && _visuals_with_bottom_right_corner = 0, "┎",
			    _visuals_with_top_left_corner = 0 && _visuals_with_top_right_corner > 0 && _visuals_with_bottom_left_corner = 0 && _visuals_with_bottom_right_corner = 0, "┓",
			    
			    _visuals_above_end_here > 0 || _visuals_below_start_here, "━",
			    _left_visuals_end_here > 0 || _right_visuals_start_here > 0, "┃",
			    _visuals_in_cell > 0, " ",
			    BLANK()
			)
			```
