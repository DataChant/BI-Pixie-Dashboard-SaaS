	measure 'Visual Key in Heatmap' = ```
			
			VAR _x_cell_size = [X Heatmap Cell Size2]
			VAR _y_cell_size = [Y Heatmap Cell Size2]
			VAR _x = MAX('X Dimension2'[X]) * _x_cell_size
			VAR _y = MAX('Y Dimension2'[Y]) * _y_cell_size
			
			VAR _filtered_table = 
			FILTER (
			    Visuals,
			    Visuals[X] <= _x + _x_cell_size && Visuals[X] + Visuals[Width] >= _x &&
			        Visuals[Y] <= _y + _y_cell_size && Visuals[Y] + Visuals[Height] >= _y
			)
			
			VAR _filtered_with_clicks =
			SUMMARIZECOLUMNS(
			    'Visuals'[Visual Key],
			    _filtered_table,
			    "@clicks", [Click Events]
			)
			
			VAR _max_events =
			MAXX(
			    _filtered_with_clicks,
			    [@clicks]
			)
			
			RETURN
			MAXX (
			    FILTER(
			        _filtered_with_clicks,
			        [@clicks] = _max_events
			    ),
			    [Visual Key]
			)
			```
		lineageTag: 6002c14b-cc83-4ef5-b47d-9bed7f3781b4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Y Heatmap Cell Size' =
			
			VAR _page_width = MAX('Pages'[Width])
			VAR _page_height = MAX('Pages'[Height])
			VAR _x_ratio = _page_width / 1280.0
			VAR _default_proportion = 1280.0 / 720.0
			VAR _proportion = DIVIDE ( _page_width, _page_height )
			VAR _corrected_height =
			IF ( _proportion < _default_proportion,
			    MAX(720, _page_height),
			    720 * MAX(1, _x_ratio)
			)
			RETURN
			_corrected_height / 36.0
		isHidden
