	measure 'Heatmap Title' = ```
			
			VAR _top_pages = TOPN(1, 'Pages', [Clicks in Visual], DESC)
			VAR _page_name = 
			CALCULATE (
			    CONCATENATEX(
			        TOPN(1, 'Pages', [Clicks in Visual], DESC),
			        'Pages'[Page Name],
			        ", "
			    )
			)
			VAR _row_count = COUNTROWS(_top_pages)
			RETURN
			SWITCH ( TRUE(),
			    SUM(License[Capability Heatmaps]) < 1, "No data found",
			    ISBLANK([Scanned visuals]), "No data found",
			    _row_count > 3, "More than 3 pages are loaded in Heatmap.",
			    _row_count > 1, "Selected Pages: " & _page_name,
			    "Selected Page: " & _page_name )
			```
		lineageTag: c3005967-1f67-4167-a115-553442781504

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Clicks in Heatmap' =
			
			VAR _result =
			SUMX (
			    Visuals,
			    VAR _x_cell_size = [X Heatmap Cell Size2]
			    VAR _y_cell_size = [Y Heatmap Cell Size2]
			    VAR _x = MAX('X Dimension2'[X]) * _x_cell_size
			    VAR _y = MAX('Y Dimension2'[Y]) * _y_cell_size
			    RETURN
			    CALCULATE(
			        [Clicks in Visual],
			        KEEPFILTERS (
			            Visuals[X] < _x && Visuals[X] + Visuals[Width] > _x + _x_cell_size &&
			            Visuals[Y] < _y && Visuals[Y] + Visuals[Height] > _y + _y_cell_size
			        )
			    )
			)
			RETURN
			_result
		formatString: #,0
		lineageTag: ebd154d0-93db-4198-8114-ba9031afb647

