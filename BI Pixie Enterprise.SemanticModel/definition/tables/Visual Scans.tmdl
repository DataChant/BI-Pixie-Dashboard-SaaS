	measure 'X Heatmap Cell Size2' =
			
			VAR _page_width = MAX('Pages'[Width])
			VAR _page_height = MAX('Pages'[Height])
			VAR _y_ratio = _page_height / 720.0
			VAR _default_proportion = 1280.0 / 720.0
			VAR _proportion = DIVIDE ( _page_width, _page_height )
			VAR _corrected_height =
			IF ( _proportion < _default_proportion,
			    1280 * MAX(1, _y_ratio),
			    MAX(1280, _page_width)
			)
			RETURN
			_corrected_height / 56
		formatString: 0.00
		isHidden
		lineageTag: 8e266466-59e5-4493-89ed-5cace6fa4709

	measure 'Y Heatmap Cell Size2' =
			
			VAR _page_width = MAX('Pages'[Width])
			VAR _page_height = MAX('Pages'[Height])
			VAR _x_ratio = _page_width / 1280.0
			VAR _default_proportion = 1280.0 / 720.0
			VAR _proportion = DIVIDE ( _page_width, _page_height )
			VAR _corrected_height =
			IF ( _proportion < _default_proportion,
			    MAX(720, _page_height),
			    720 * MAX(1, _x_ratio)
			)
			RETURN
			_corrected_height / 55
