table License
	lineageTag: 6422a6ad-62cf-4fd7-9325-ae3090539c4c

	measure 'Performance License' =
			
			IF (
			    AND (
			        SUM ( License[Capability Performance] ) > 0,
			        SUM ( License[Capability Heatmaps] ) > 0
			    ),
			    "",
			    "Not supported in current subscription"
			)
		lineageTag: a72a983c-58d0-4d2e-8ab0-8ab7781b8af6

