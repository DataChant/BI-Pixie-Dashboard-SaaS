	partition License = m
		mode: import
		source = ```
				let
				    URL = "https://db1e5e5304aaed148ffa083150a247.13.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/df00f746a51540d2af36df8bf6a9f99e/triggers/manual/paths/invoke?api-version=1&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=Q8_bRq56zFZSAgf_DXjmFsMjnEO473GkVeDP32u6T8Q",
				    Query = [
				        dse = #"Subscription Email",
				        lk = #"License Key",
				        rt =  "refresh",
				        tr = reports,
				        tu = users
				    ],
				    
				    LicenseResponse = Json.Document(
				        Web.Contents(URL,
				            [
				                Query = Query,
				                Headers = [
				                    #"Content-Type" = "application/json"
				                ]
				            ]
				        )
				    ),
				    #"Converted to Table" = Table.FromRecords({LicenseResponse}),
				    LicenseTable = Table.TransformColumnTypes(#"Converted to Table",{{"Subscription End Date", type datetimezone}, {"Max Allowed Users", Int64.Type}, {"Max Allowed Reports", Int64.Type}, {"Max Allowed Monthly Scans", Int64.Type}, {"Total Users", Int64.Type}, {"Total Reports Used", Int64.Type}, {"Total Reports Scanned", Int64.Type}, {"Total Scans", Int64.Type}, {"Capability Custom Data", Int64.Type}, {"Capability Heatmaps", Int64.Type}, {"Capability Filtered Values", Int64.Type}, {"Capability Security", Int64.Type}, {"Capability Performance", Int64.Type}, {"Capability User Satisfaction", Int64.Type}}),
				    
				    Source = AzureStorage.DataLake(#"Data Lake URL",[HierarchicalNavigation=true]),
				    #"Filtered Rows" = Table.SelectRows(Source, each [Name] = #"License Key"),
				    #"Removed Other Columns" = Table.SelectColumns(#"Filtered Rows",{"Content"}),
				    #"Expanded Content2" = Table.ExpandTableColumn(#"Removed Other Columns", "Content", {"Content", "Name"}, {"Content", "Name"}),
				    #"Filtered Rows3" = Table.SelectRows(#"Expanded Content2", each ([Name] = "events")),
				    #"Removed Columns1" = Table.RemoveColumns(#"Filtered Rows3",{"Name"}),
				    #"Expanded Content" = Table.ExpandTableColumn(#"Removed Columns1", "Content", {"Content", "Name"}, {"Content.1", "Project"}),
				    Reports = Table.ExpandTableColumn(#"Expanded Content", "Content.1", {"Content", "Name"}, {"Content", "Report"}),
				    #"Expanded Content3" = Table.ExpandTableColumn(Reports, "Content", {"Name"}, {"User"}),
				    Users = Table.Distinct(#"Expanded Content3", {"User"}),
				    #"Merged Columns" = Table.CombineColumns(Users,{"Project", "Report"},Combiner.CombineTextByDelimiter("/", QuoteStyle.None),"Report"),
				    #"Removed Duplicates" = Table.Distinct(#"Merged Columns"),
				
				    
				    events_buffer = Table.Buffer(#"Removed Duplicates"),
				    users = Text.From(Table.RowCount(Users)),
				    reports = Text.From(Table.RowCount(Reports)),
				    
				    capabilities = LicenseResponse[Capability Custom Data] +
				        LicenseResponse[Capability Heatmaps] +
				        LicenseResponse[Capability Filtered Values] + 
				        LicenseResponse[Capability Security] +
				        LicenseResponse[Capability Performance] + 
				        LicenseResponse[Capability User Satisfaction], 
				    res =
				        if (LicenseResponse[Status] = "active" or LicenseResponse[Status] = "trial") then
				            LicenseTable
				        else
				            error Error.Record("Reason: " & LicenseResponse[#"Status Reason"] , "Message: Failed to refresh BI Pixie."  & LicenseResponse[#"Status Detail"] & "., Detail: " & LicenseResponse[#"Status Detail"])    
				in
				    res
				```

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

