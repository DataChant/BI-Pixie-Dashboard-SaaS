			VAR _visual_key =
			    CALCULATE (
			        MAX ( 'Visuals'[Visual Key] ),
			        KEEPFILTERS ( 'Visual Trust Levels'[Order] = _lowest_trust ),
			        _all_visuals_in_area
			    )
			VAR _result =
			    IF (
			        _lowest_trust = -1,
			        BLANK(),
			        _visual_key
