table Visuals
	lineageTag: 9ef96648-35e6-4ba1-8d63-04c6dafaa430

	measure 'Count of Visuals' = COUNTROWS ( Visuals )
		formatString: #,0
		lineageTag: 54596833-7182-4db6-a8de-9d69834964bb

	measure 'Certified Visuals' = CALCULATE([Count of Visuals], 'All Visual Types'[Visual State] = "Certified")
		formatString: #,0
		lineageTag: 64f6c416-16a4-45e0-a754-2373a3f6030f

	measure 'Trust State in Heatmap' = ```
			
			VAR _cell_size_x = [X Heatmap Cell Size2]
			VAR _cell_size_y = [Y Heatmap Cell Size2] 
			VAR _x = MAX('X Dimension2'[X]) * _cell_size_x
			VAR _y = MAX('Y Dimension2'[Y]) * _cell_size_y
			VAR _pages = DISTINCTCOUNT('Visual Scans'[Report Page Key])
			
			VAR _all_visuals_in_area =
			    FILTER (
			        'Visuals',
			        Visuals[X] < _x && Visuals[X] + Visuals[Width] > _x + _cell_size_x &&
			        Visuals[Y] < _y && Visuals[Y] + Visuals[Height] > _y + _cell_size_y
			    )
			
			VAR _lowest_trust =
			    MAXX (
			        _all_visuals_in_area,
			        VAR _current_visual_type = 'Visuals'[Visual Type]
			        VAR _visual_state =
			            CALCULATE(
			                MAX ( 'All Visual Types'[Visual State] ),
			                KEEPFILTERS ( 'All Visual Types'[GUID] = _current_visual_type )
			            )
			        VAR _order_value = 
			            CALCULATE(
			                MIN ('Visual Trust Levels'[Order]),
			                KEEPFILTERS ( 'Visual Trust Levels'[Visual State] = _visual_state )
			            )
			        RETURN
			        IF(ISBLANK(_order_value), -1, _order_value)
			    )
			
			VAR _result =
			    IF (
			        _lowest_trust = -1 || _pages > 1,
			        BLANK(),
			        CALCULATE (
			            MAX ('Visual Trust Levels'[CF] ),
			            KEEPFILTERS ( 'Visual Trust Levels'[Order] = _lowest_trust )
			        )
			    )
			
			RETURN
			_result
			```
		lineageTag: c4e82596-c4d0-45b5-9e6c-656d7172895c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Uncertified Visuals' = CALCULATE([Count of Visuals], 'All Visual Types'[Visual State] = "Not Certified")
		formatString: #,0
		lineageTag: 0dca4e3a-9cf8-473b-bb14-18323fae7a5c

	measure 'Risky Visuals' = CALCULATE([Count of Visuals], 'Visual Trust Levels'[Visual State] IN {"Unlisted", "Unknown"})
		formatString: 0
		lineageTag: 9efa2f5c-cab1-495f-a938-19ce8fceb32d

	measure 'Visual Type in Custom Visuals Heatmap' = ```
			
			VAR _cell_size_x = [X Heatmap Cell Size2]
			VAR _cell_size_y = [Y Heatmap Cell Size2] 
			VAR _x = MAX('X Dimension2'[X]) * _cell_size_x
			VAR _y = MAX('Y Dimension2'[Y]) * _cell_size_y
			
			VAR _all_visuals_in_area =
			    FILTER (
			        'Visuals',
			        [Visual X] < _x && [Visual X] + [Visual width] > _x + _cell_size_x &&
			        [Visual Y] < _y && [Visual Y] + [Visual height] > _y + _cell_size_y
			    )
			
			VAR _lowest_trust =
			    MAXX (
			        _all_visuals_in_area,
			        VAR _current_visual_type = 'Visuals'[Visual Type]
			        VAR _visual_state =
			            CALCULATE(
			                MAX ( 'All Visual Types'[Visual State] ),
			                FILTER (
			                    'All Visual Types',
			                    'All Visual Types'[GUID] = _current_visual_type
			                )
			            )
			        VAR _order_value = 
			            CALCULATE(
			                MIN ('Visual Trust Levels'[Order]),
			                FILTER (
			                    'Visual Trust Levels',
			                    'Visual Trust Levels'[Visual State] = _visual_state
			                )
			            )
			        RETURN
			        IF(ISBLANK(_order_value), -1, _order_value)
			    )
			
			VAR _visual_type =
			    CALCULATE (
			        MAX ( 'All Visual Types'[Visual Type] ),
			        KEEPFILTERS ( 'Visual Trust Levels'[Order] = _lowest_trust ),
			        _all_visuals_in_area
			    )
			VAR _result =
			    IF (
			        _lowest_trust = -1,
			        BLANK(),
			        _visual_type
			    )
			
			RETURN
			_result
			```
		lineageTag: ed9f2cc4-553c-4be9-a9f4-6c4333339466

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Custom Visuals Heatmap Title' =
			
			VAR _page_name = SELECTEDVALUE('Pages'[Page Name])
			RETURN
			SWITCH (
			    TRUE(),
			    ISBLANK([Scanned visuals]), "No data found",
			    ISBLANK(_page_name), "Select a page to track its Custom Visuals in the Heatmap.",
			    "Selected Page: " & _page_name )
		lineageTag: c057d410-66b3-4072-bfd0-a8c307a6bb52

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Visual Key in Custom Visuals Heatmap' = ```
			
			VAR _cell_size_x = [X Heatmap Cell Size2]
			VAR _cell_size_y = [Y Heatmap Cell Size2] 
			VAR _x = MAX('X Dimension2'[X]) * _cell_size_x
			VAR _y = MAX('Y Dimension2'[Y]) * _cell_size_y
			
			VAR _all_visuals_in_area =
			    FILTER (
			        'Visuals',
			        [Visual X] < _x && [Visual X] + [Visual width] > _x + _cell_size_x &&
			        [Visual Y] < _y && [Visual Y] + [Visual height] > _y + _cell_size_y
			    )
			
			VAR _lowest_trust =
			    MAXX (
			        _all_visuals_in_area,
			        VAR _current_visual_type = 'Visuals'[Visual Type]
			        VAR _visual_state =
			            CALCULATE(
			                MAX ( 'All Visual Types'[Visual State] ),
			                FILTER (
			                    'All Visual Types',
			                    'All Visual Types'[GUID] = _current_visual_type
			                )
			            )
			        VAR _order_value = 
			            CALCULATE(
			                MIN ('Visual Trust Levels'[Order]),
			                FILTER (
			                    'Visual Trust Levels',
			                    'Visual Trust Levels'[Visual State] = _visual_state
			                )
			            )
			        RETURN
			        IF(ISBLANK(_order_value), -1, _order_value)
