	measure 'Visual ID in Custom Visuals Heatmap' =
			
			CALCULATE (
			    MAX ( Visuals[Visual ID] ),
			    FILTER (
			        Visuals,
			        Visuals[Visual Key] = [Visual Key in Custom Visuals Heatmap]
			    )
			)
