		summarizeBy: none
		sourceColumn: Date

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column 'DAX Query'
		dataType: string
		lineageTag: 06691fa3-bfc8-411e-a7eb-73ec2ed72ddb
