table 'Performance Queries'
	lineageTag: 758fc20a-960a-48ac-ab61-b52b70f1a8fc

	measure 'Sampled DAX Query' =
			
			VAR _max_date = MAX('Performance Queries'[Date])
			RETURN
			CALCULATE (
			    MIN ( 'Performance Queries'[DAX Query] ),
			    KEEPFILTERS ( 'Performance Queries'[Date] = _max_date )
			)
		lineageTag: 5e1e4bc1-ed47-4f63-b5ab-ac75bd5ef640

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column Date
		dataType: dateTime
		isHidden
		formatString: Long Date
